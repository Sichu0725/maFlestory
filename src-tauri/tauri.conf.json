{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "maFlestory",
  "version": "0.1.0",
  "identifier": "com.maflestory.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "maFlestory",
        "width": 960,
        "height": 640,
        "decorations": true,
        "transparent": false,
        "alwaysOnBottom": true,
        "skipTaskbar": false,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
